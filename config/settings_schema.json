[
  {
    "name": "theme_info",
    "theme_name": "Beatz",
    "theme_version": "1.0.0",
    "theme_author": "Beatz Studio",
    "theme_documentation_url": "https://beatz-theme.com/docs",
    "theme_support_url": "https://beatz-theme.com/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary Colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary accent",
        "default": "#C9A96E",
        "info": "Gold accent used for buttons, links, and highlights"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary accent",
        "default": "#1A1A2E",
        "info": "Deep navy used for headings and contrast elements"
      },
      {
        "type": "color",
        "id": "color_tertiary",
        "label": "Tertiary accent",
        "default": "#E8D5B7",
        "info": "Warm champagne for subtle backgrounds"
      },
      {
        "type": "header",
        "content": "Background Colors"
      },
      {
        "type": "color",
        "id": "color_bg_primary",
        "label": "Primary background",
        "default": "#FAFAFA"
      },
      {
        "type": "color",
        "id": "color_bg_secondary",
        "label": "Secondary background",
        "default": "#F5F0EB"
      },
      {
        "type": "color",
        "id": "color_bg_dark",
        "label": "Dark background",
        "default": "#0D0D0D"
      },
      {
        "type": "header",
        "content": "Text Colors"
      },
      {
        "type": "color",
        "id": "color_text_primary",
        "label": "Primary text",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text",
        "default": "#6B6B6B"
      },
      {
        "type": "color",
        "id": "color_text_light",
        "label": "Light text",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "playfair_display_n7"
      },
      {
        "type": "range",
        "id": "font_heading_scale",
        "label": "Heading font size scale",
        "min": 80,
        "max": 150,
        "step": 5,
        "default": 100,
        "unit": "%"
      },
      {
        "type": "header",
        "content": "Body"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_body_scale",
        "label": "Body font size scale",
        "min": 80,
        "max": 130,
        "step": 5,
        "default": 100,
        "unit": "%"
      },
      {
        "type": "header",
        "content": "Accent Font"
      },
      {
        "type": "font_picker",
        "id": "font_accent",
        "label": "Accent font",
        "default": "cormorant_garamond_n3"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "default": 1400,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Space between sections",
        "min": 0,
        "max": 100,
        "step": 4,
        "default": 40,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "border_radius_style",
        "label": "Border radius style",
        "options": [
          { "value": "none", "label": "Sharp" },
          { "value": "small", "label": "Slightly rounded" },
          { "value": "medium", "label": "Rounded" },
          { "value": "pill", "label": "Pill" }
        ],
        "default": "small"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_show_free_shipping_bar",
        "label": "Show free shipping progress bar",
        "default": true
      },
      {
        "type": "text",
        "id": "cart_free_shipping_threshold",
        "label": "Free shipping threshold",
        "default": "100",
        "info": "Enter amount without currency symbol"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "X (Twitter) URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  }
]
