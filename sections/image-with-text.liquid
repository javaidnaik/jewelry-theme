{%- assign reversed = section.settings.image_position == 'right' -%}

<div class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
      <div style="{% if reversed %}order: 2;{% endif %}" data-animate="{% if reversed %}fade-right{% else %}fade-left{% endif %}">
        <div style="border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: {{ section.settings.image_ratio }};">
          {%- if section.settings.image -%}
            {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(min-width: 769px) 50vw, 100vw' }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      <div style="{% if reversed %}order: 1;{% endif %}" data-animate="{% if reversed %}fade-left{% else %}fade-right{% endif %}">
        {%- if section.settings.label != blank -%}
          <p class="section-label">{{ section.settings.label }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="h2" style="margin-bottom: 16px;">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div style="font-size: 1rem; line-height: 1.8; color: var(--color-text-secondary); margin-bottom: 32px;">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary">
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    [data-section-id="{{ section.id }}"] > .container > div {
      grid-template-columns: 1fr !important;
    }
    [data-section-id="{{ section.id }}"] > .container > div > *  {
      order: unset !important;
    }
  }
</style>

{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "class": "section-image-text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "1/1", "label": "Square" },
        { "value": "4/3", "label": "Landscape (4:3)" }
      ],
      "default": "3/4"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Image with text"
    }
  ],
  "enabled_on": {
    "templates": ["*"],
    "groups": ["body", "aside"]
  }
}
{% endschema %}
