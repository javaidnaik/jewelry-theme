{%- assign transparent = false -%}
{%- if template.name == 'index' and section.settings.transparent_home -%}
  {%- assign transparent = true -%}
{%- endif -%}

<header class="header{% if transparent %} header--transparent{% endif %}" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="header__inner">
      {%- comment -%} Mobile menu button {%- endcomment -%}
      <button class="header__menu-btn btn--icon" aria-label="Open menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      {%- comment -%} Logo {%- endcomment -%}
      <a href="/" class="header__logo">
        {%- if section.settings.logo -%}
          {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>

      {%- comment -%} Main navigation {%- endcomment -%}
      <nav class="header__nav" aria-label="Main navigation">
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="header__nav-item" style="position: relative;">
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}">
                {{ link.title }}
              </a>
              <div class="mega-menu">
                <div class="container">
                  <div class="mega-menu__grid">
                    {%- for child_link in link.links -%}
                      <div>
                        <h4 class="mega-menu__column-title">{{ child_link.title }}</h4>
                        {%- for grandchild_link in child_link.links -%}
                          <a href="{{ grandchild_link.url }}" class="mega-menu__link">{{ grandchild_link.title }}</a>
                        {%- endfor -%}
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}">
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      {%- comment -%} Action icons {%- endcomment -%}
      <div class="header__actions">
        {%- comment -%} Search {%- endcomment -%}
        <button class="btn--icon" data-search-open aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
        </button>

        {%- comment -%} Account {%- endcomment -%}
        <a href="{{ routes.account_url }}" class="btn--icon" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>

        {%- comment -%} Cart {%- endcomment -%}
        <button class="btn--icon" data-cart-open aria-label="Cart" style="position: relative;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="header__cart-count" style="{% if cart.item_count == 0 %}display:none{% endif %}">
            {{ cart.item_count }}
          </span>
        </button>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "section-header-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 250,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "transparent_home",
      "label": "Transparent header on homepage",
      "default": true,
      "info": "Header will be transparent over the hero banner"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
