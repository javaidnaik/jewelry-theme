<div
  class="hero-banner hero-banner--{{ section.settings.height }}"
  data-section-id="{{ section.id }}"
  style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="hero-banner__media">
    {%- if section.settings.video_url != blank -%}
      <video autoplay muted loop playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', class: 'parallax', data-parallax-speed: '0.15'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="hero-banner__overlay"></div>

  <div class="hero-banner__content hero-banner__content--{{ section.settings.text_position }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero-banner__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="hero-banner__actions">
      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--outline-light">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_text_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="btn btn--link" style="color: var(--color-primary); border-color: var(--color-primary);">
          {{ section.settings.button_text_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero-banner__scroll-indicator">
      <div class="hero-banner__scroll-line"></div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "section-hero-banner section--flush",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL",
      "info": "MP4 format recommended. Overrides image if set."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Season"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury Redefined"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover handcrafted jewelry and curated fashion that speaks to your soul"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "full", "label": "Full screen" },
        { "value": "large", "label": "Large" },
        { "value": "medium", "label": "Medium" },
        { "value": "small", "label": "Small" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Extras"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ],
  "enabled_on": {
    "templates": ["*"],
    "groups": ["body", "aside"]
  }
}
{% endschema %}
