<div class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.label != blank -%}
        <p class="section-label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="section-header__divider"></div>
    </div>

    <div class="collection-list__grid" data-stagger>
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection.url | default: '#' }}" class="collection-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'collection-card__image', sizes: '(min-width: 769px) 33vw, 50vw' }}
          {%- elsif block.settings.collection.image -%}
            {{ block.settings.collection.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'collection-card__image', sizes: '(min-width: 769px) 33vw, 50vw' }}
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg collection-card__image' }}
          {%- endif -%}

          <div class="collection-card__overlay">
            <h3 class="collection-card__title">
              {{ block.settings.collection.title | default: block.settings.title | default: 'Collection' }}
            </h3>
            {%- if block.settings.collection -%}
              <p class="collection-card__count">{{ block.settings.collection.products_count }} products</p>
            {%- endif -%}
            <span class="collection-card__link">Shop Now →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "class": "section-collection-list",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find your perfect piece"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Overrides collection title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Overrides collection image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection", "settings": { "title": "Rings" } },
        { "type": "collection", "settings": { "title": "Necklaces" } },
        { "type": "collection", "settings": { "title": "Bracelets" } }
      ]
    }
  ],
  "max_blocks": 6,
  "enabled_on": {
    "templates": ["*"],
    "groups": ["body", "aside"]
  }
}
{% endschema %}
