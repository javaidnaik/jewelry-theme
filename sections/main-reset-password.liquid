<div class="section" data-section-id="{{ section.id }}">
  <div class="container" style="max-width: 480px;">
    <div style="text-align: center; padding: 60px 0;" data-animate>
      <h1 class="h2" style="margin-bottom: 12px;">{{ 'customer.reset_password.title' | t }}</h1>
      <p style="color: var(--color-text-secondary); margin-bottom: 32px;">{{ 'customer.reset_password.subtext' | t: email: email }}</p>

      {% form 'reset_customer_password' %}
        {{ form.errors | default_errors }}

        <div style="margin-bottom: 20px; text-align: left;">
          <label for="ResetPassword" style="display: block; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 8px;">{{ 'customer.reset_password.password' | t }}</label>
          <input type="password" name="customer[password]" id="ResetPassword" autocomplete="new-password" required style="width: 100%; padding: 14px 16px; border: 1px solid rgba(0,0,0,0.15); border-radius: var(--radius-sm); font-size: 0.9rem;">
        </div>

        <div style="margin-bottom: 24px; text-align: left;">
          <label for="ResetPasswordConfirm" style="display: block; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 8px;">{{ 'customer.reset_password.password_confirm' | t }}</label>
          <input type="password" name="customer[password_confirmation]" id="ResetPasswordConfirm" autocomplete="new-password" required style="width: 100%; padding: 14px 16px; border: 1px solid rgba(0,0,0,0.15); border-radius: var(--radius-sm); font-size: 0.9rem;">
        </div>

        <button type="submit" class="btn btn--primary" style="width: 100%;">{{ 'customer.reset_password.submit' | t }}</button>
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Reset password",
  "tag": "section",
  "class": "section-reset-password",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
