{%- if section.settings.show_bar -%}
<div class="announcement-bar" data-section-id="{{ section.id }}">
  <div class="announcement-bar__track" aria-label="Announcement">
    {%- for i in (1..6) -%}
      <span class="announcement-bar__text">{{ section.settings.text }}</span>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "FREE SHIPPING ON ORDERS OVER $100 | NEW COLLECTION JUST DROPPED"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1A1A2E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
