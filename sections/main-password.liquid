<div class="password-page" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--color-bg-dark); color: var(--color-text-light); text-align: center; padding: 40px 24px;">
  <div style="max-width: 520px;">
    <a href="/" class="header__logo" style="color: #fff; display: inline-block; margin-bottom: 40px;">{{ shop.name }}</a>

    <h1 style="font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 16px; color: #fff;">
      {{ section.settings.heading | default: 'Opening Soon' }}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p style="font-family: var(--font-accent); font-style: italic; font-size: 1.1rem; color: rgba(255,255,255,0.6); margin-bottom: 40px;">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    {%- if section.settings.show_password_form -%}
      <div style="margin-bottom: 40px;">
        <p style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-bottom: 16px;">{{ 'general.password_page.login_form_heading' | t }}</p>
        {% form 'storefront_password', class: 'newsletter__form' %}
          {{ form.errors | default_errors }}
          <input
            type="password"
            name="password"
            class="newsletter__input"
            placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
            aria-label="{{ 'general.password_page.login_form_password_label' | t }}"
            required
          >
          <button type="submit" class="newsletter__submit">
            {{ 'general.password_page.login_form_submit' | t }}
          </button>
        {% endform %}
      </div>
    {%- endif -%}

    {%- if section.settings.show_newsletter -%}
      <div style="margin-bottom: 40px;">
        <p style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-bottom: 16px;">Be the first to know when we launch.</p>
        {% form 'customer', class: 'newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="password-page">
          <input
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="Enter your email"
            required
            autocomplete="email"
            aria-label="Email"
          >
          <button type="submit" class="newsletter__submit">Notify Me</button>
        {% endform %}
      </div>
    {%- endif -%}

    <p style="font-size: 0.75rem; color: rgba(255,255,255,0.3); margin-top: 60px;">
      {{ 'general.password_page.admin_link_html' | t }}
    </p>

    <p style="font-size: 0.7rem; color: rgba(255,255,255,0.2); margin-top: 16px;">
      {{ 'general.password_page.powered_by_shopify_html' | t }}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "section-password",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're working on something beautiful. Stay tuned."
    },
    {
      "type": "checkbox",
      "id": "show_password_form",
      "label": "Show password form",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    }
  ]
}
{% endschema %}
