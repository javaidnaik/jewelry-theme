<div class="section" data-section-id="{{ section.id }}">
  <div class="container" style="max-width: 800px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; flex-wrap: wrap; gap: 16px;" data-animate>
      <div>
        <a href="{{ routes.account_url }}" style="font-size: 0.85rem; color: var(--color-primary);">← {{ 'customer.account.return' | t }}</a>
        <h1 class="h2" style="margin-top: 8px;">{{ 'customer.addresses.title' | t }}</h1>
      </div>
      <button onclick="document.getElementById('AddressNewForm').style.display = document.getElementById('AddressNewForm').style.display === 'none' ? 'block' : 'none'" class="btn btn--primary" style="padding: 12px 24px; font-size: 0.75rem;">
        {{ 'customer.addresses.add_new' | t }}
      </button>
    </div>

    {%- comment -%} New address form {%- endcomment -%}
    <div id="AddressNewForm" style="display: none; margin-bottom: 48px; padding: 32px; background: var(--color-bg-secondary); border-radius: var(--radius-lg);">
      <h2 class="h4" style="margin-bottom: 24px;">{{ 'customer.addresses.add_new' | t }}</h2>
      {% form 'customer_address', customer.new_address %}
        {% render 'address-form', form: form %}
        <div style="display: flex; gap: 12px; margin-top: 24px;">
          <button type="submit" class="btn btn--primary" style="padding: 12px 24px; font-size: 0.75rem;">{{ 'customer.addresses.add' | t }}</button>
          <button type="button" onclick="document.getElementById('AddressNewForm').style.display='none'" class="btn btn--outline" style="padding: 12px 24px; font-size: 0.75rem;">{{ 'customer.addresses.cancel' | t }}</button>
        </div>
      {% endform %}
    </div>

    {%- comment -%} Existing addresses {%- endcomment -%}
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      {%- for address in customer.addresses -%}
        <div style="padding: 24px; border: 1px solid rgba(0,0,0,0.08); border-radius: var(--radius-md); position: relative;">
          {%- if address == customer.default_address -%}
            <span style="position: absolute; top: 12px; right: 12px; padding: 4px 10px; background: var(--color-primary); color: #fff; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; border-radius: var(--radius-sm);">{{ 'customer.addresses.default' | t }}</span>
          {%- endif -%}

          <div style="font-size: 0.9rem; line-height: 1.7; color: var(--color-text-secondary); margin-bottom: 16px;">
            {{ address | format_address }}
          </div>

          <div style="display: flex; gap: 12px;">
            <button onclick="document.getElementById('EditAddress_{{ address.id }}').style.display = document.getElementById('EditAddress_{{ address.id }}').style.display === 'none' ? 'block' : 'none'" style="font-size: 0.8rem; color: var(--color-primary); font-weight: 600; background: none; border: none; cursor: pointer;">{{ 'customer.addresses.edit' | t }}</button>
            {% form 'customer_address', address %}
              <input type="hidden" name="_method" value="delete">
              <button type="submit" onclick="return confirm('{{ 'customer.addresses.delete_confirm' | t }}')" style="font-size: 0.8rem; color: #e74c3c; background: none; border: none; cursor: pointer;">{{ 'customer.addresses.delete' | t }}</button>
            {% endform %}
          </div>

          {%- comment -%} Edit form {%- endcomment -%}
          <div id="EditAddress_{{ address.id }}" style="display: none; margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(0,0,0,0.08);">
            {% form 'customer_address', address %}
              {% render 'address-form', form: form %}
              <div style="display: flex; gap: 12px; margin-top: 16px;">
                <button type="submit" class="btn btn--primary" style="padding: 10px 20px; font-size: 0.75rem;">{{ 'customer.addresses.update' | t }}</button>
                <button type="button" onclick="document.getElementById('EditAddress_{{ address.id }}').style.display='none'" class="btn btn--outline" style="padding: 10px 20px; font-size: 0.75rem;">{{ 'customer.addresses.cancel' | t }}</button>
              </div>
            {% endform %}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer addresses",
  "tag": "section",
  "class": "section-addresses",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
