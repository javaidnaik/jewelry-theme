<div class="split-lookbook section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.label != blank -%}
        <p class="section-label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="section-header__divider"></div>
    </div>

    <div class="split-lookbook__grid" data-stagger>
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="split-lookbook__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 769px) 50vw, 100vw' }}
          {%- else -%}
            {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="split-lookbook__overlay">
            {%- if block.settings.title != blank -%}
              <h3 class="split-lookbook__overlay-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            <span class="split-lookbook__overlay-link">Shop the Look →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split lookbook",
  "tag": "section",
  "class": "section-split-lookbook",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Editorial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Lookbook"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Style inspiration from our latest editorial"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Lookbook image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Winter Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split lookbook",
      "blocks": [
        { "type": "image", "settings": { "title": "Signature Rings" } },
        { "type": "image", "settings": { "title": "Gold Essentials" } },
        { "type": "image", "settings": { "title": "Layered Necklaces" } }
      ]
    }
  ],
  "max_blocks": 5,
  "enabled_on": {
    "templates": ["*"],
    "groups": ["body", "aside"]
  }
}
{% endschema %}
