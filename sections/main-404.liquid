<div class="page-404 section" data-section-id="{{ section.id }}">
  <div class="container">
    <div data-animate>
      <h1 class="page-404__heading">404</h1>
      <p class="page-404__text">The page you're looking for doesn't exist. Perhaps it was moved, or maybe it was just a dream.</p>
      <a href="/" class="btn btn--primary">Return Home</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404 page",
  "tag": "section",
  "class": "section-404",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
