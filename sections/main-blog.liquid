<div class="section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-header" data-animate>
      <p class="section-label">Journal</p>
      <h1 class="section-header__heading h2">{{ blog.title }}</h1>
    </div>

    <div class="grid grid--3" data-stagger>
      {%- paginate blog.articles by 9 -%}
        {%- for article in blog.articles -%}
          <article class="product-card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="product-card__media" style="aspect-ratio: 16/10;">
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 769px) 33vw, 100vw' }}
              </a>
            {%- endif -%}
            <div class="product-card__info">
              <p class="product-card__vendor">{{ article.published_at | date: '%B %d, %Y' }}</p>
              <h3 class="product-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              <p style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.6;">
                {{ article.excerpt_or_content | strip_html | truncate: 120 }}
              </p>
              <a href="{{ article.url }}" class="btn--link" style="margin-top: 12px; display: inline-block;">
                Read More
              </a>
            </div>
          </article>
        {%- endfor -%}
      {%- endpaginate -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "class": "section-blog",
  "settings": []
}
{% endschema %}
