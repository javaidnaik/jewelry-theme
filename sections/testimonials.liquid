<div class="testimonials section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.label != blank -%}
        <p class="section-label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="section-header__divider"></div>
    </div>

    <div class="testimonials__wrapper" style="overflow: hidden;">
      <div class="testimonials__slider">
        {%- for block in section.blocks -%}
          <div class="testimonials__slide" {{ block.shopify_attributes }}>
            <div class="testimonials__stars">
              {%- for i in (1..block.settings.rating) -%}
                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
            </div>

            <blockquote class="testimonials__quote">
              "{{ block.settings.quote }}"
            </blockquote>

            <div class="testimonials__author">
              {%- if block.settings.avatar -%}
                <div class="testimonials__author-avatar">
                  {{ block.settings.avatar | image_url: width: 96 | image_tag }}
                </div>
              {%- else -%}
                <div class="testimonials__author-avatar" style="background: var(--color-primary); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 1.1rem;">
                  {{ block.settings.author | slice: 0 }}
                </div>
              {%- endif -%}
              <div>
                <div class="testimonials__author-name">{{ block.settings.author }}</div>
                {%- if block.settings.title != blank -%}
                  <div class="testimonials__author-title">{{ block.settings.title }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="testimonials__nav">
        <button class="testimonials__nav-btn testimonials__nav-btn--prev" aria-label="Previous testimonial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <button class="testimonials__nav-btn testimonials__nav-btn--next" aria-label="Next testimonial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What They Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Loved by thousands of customers worldwide"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The craftsmanship is absolutely exquisite. I've never owned jewelry that makes me feel so special. Beatz has become my go-to for every occasion."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah Mitchell"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Author title",
          "default": "Verified Buyer"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "The craftsmanship is absolutely exquisite. I've never owned jewelry that makes me feel so special. Beatz has become my go-to for every occasion.",
            "author": "Sarah Mitchell",
            "title": "Verified Buyer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Fast shipping, beautiful packaging, and the necklace exceeded my expectations. The attention to detail is unmatched. Will definitely order again!",
            "author": "Jessica Chen",
            "title": "Verified Buyer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "I bought matching bracelets for my bridesmaids and they were all in tears. Beatz made our special day even more memorable. Thank you!",
            "author": "Amanda Rossi",
            "title": "Verified Buyer"
          }
        }
      ]
    }
  ],
  "max_blocks": 8,
  "enabled_on": {
    "templates": ["*"],
    "groups": ["body", "aside"]
  }
}
{% endschema %}
