<div class="marquee-text" style="--marquee-speed: {{ section.settings.speed }}s;" data-section-id="{{ section.id }}">
  <div class="marquee-text__track">
    {%- for i in (1..8) -%}
      <span class="marquee-text__text">
        {%- assign words = section.settings.text | split: ' — ' -%}
        {%- for word in words -%}
          {%- assign mod = forloop.index | modulo: 3 -%}
          {%- if mod == 0 -%}
            <span>{{ word }}</span>
          {%- else -%}
            {{ word }}
          {%- endif -%}
          {%- unless forloop.last %} — {% endunless -%}
        {%- endfor -%}
      </span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee text",
  "tag": "section",
  "class": "section-marquee section--flush",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Scrolling text",
      "default": "BEATZ — LUXURY JEWELRY — FASHION FORWARD — HANDCRAFTED — TIMELESS ELEGANCE —"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation speed (seconds)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30,
      "unit": "s"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    }
  ],
  "presets": [
    {
      "name": "Marquee text"
    }
  ],
  "enabled_on": {
    "templates": ["*"],
    "groups": ["body", "aside"]
  }
}
{% endschema %}
