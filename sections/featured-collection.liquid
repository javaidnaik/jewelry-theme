<div class="featured-collection section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="section-header" data-animate>
      {%- if section.settings.label != blank -%}
        <p class="section-label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="section-header__divider"></div>
    </div>

    <div
      class="collection-scroll"
      style="--cols: {{ section.settings.columns }};"
      data-stagger
    >
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product, show_vendor: section.settings.show_vendor, show_swatches: section.settings.show_swatches %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="product-card">
            <div class="product-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <p class="product-card__vendor">Brand Name</p>
              <h3 class="product-card__title"><a href="#">Example Product {{ i }}</a></h3>
              <div class="product-card__price">{{ 4999 | money }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and section.settings.collection != blank -%}
      <div class="featured-collection__actions" data-animate>
        <a href="{{ section.settings.collection.url }}" class="btn btn--outline">
          View All {{ section.settings.collection.title }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Curated"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The latest pieces from our atelier"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
